{
  "name": "repo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "sandbox:init": "node packages/create-project-arch/dist/cli.js testProject --force && cd testProject && pnpm install",
    "sandbox:dev": "cd testProject && pnpm dev",
    "sandbox:sync": "node scripts/sync-templates.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}