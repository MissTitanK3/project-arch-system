{
  "name": "project-arch",
  "version": "1.7.0",
  "private": false,
  "description": "Architecture-centric project management CLI and SDK for managing phases, milestones, tasks, and architectural decisions",
  "keywords": [
    "project-management",
    "architecture",
    "cli",
    "adr",
    "architecture-decision-records",
    "task-management",
    "milestones",
    "phases",
    "monorepo",
    "typescript"
  ],
  "homepage": "https://github.com/MissTitanK3/project-arch-system#readme",
  "bugs": {
    "url": "https://github.com/MissTitanK3/project-arch-system/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MissTitanK3/project-arch-system.git",
    "directory": "packages/project-arch"
  },
  "license": "MIT",
  "author": "Project Arch Contributors",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "pa": "dist/cli.js"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "release:prepare": "node ./scripts/release-prepare.mjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.8",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.8.2"
  }
}
