{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/navigation/experimentalArtifactBrowser/client/**/*.ts",
    "src/navigation/experimentalArtifactBrowser/client/**/*.tsx",
    "src/navigation/experimentalArtifactBrowser/client/**/*.d.ts"
  ]
}
